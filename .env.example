# Area Coach Tools — Windows admin

STORE_CREDENTIALS_KEY=change-this-long-random-secret
STORE_CREDENTIALS_DIR=Y:\Taco Bell Dashboard\shared\store-logins
STORELIST_PATH=Y:\Taco Bell Dashboard\shared\.storelist

PORT=3100
DASHBOARD_TIME_ZONE=Australia/Melbourne

SCRAPER_HEADLESS=true
FORECAST_SCRAPER_HEADLESS=true

# LifeLenz location tree area (must be selected before stores for some accounts)
LIFELENZ_AREA=T22

# Optional: override built-in Build-to package (default: ./mmx-report-automation)
# MMX_REPORT_AUTOMATION_DIR=

# Optional local gate
# ADMIN_HOST_TOKEN=
