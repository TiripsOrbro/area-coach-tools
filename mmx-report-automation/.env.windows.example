# Windows-only settings (not used on Pi)
# Setup:  cp .env.windows.example .env.windows
# Workbook paths live in .env (MMX_BUILD_TO_DIR_ONEDRIVE / _PI / _FALLBACK) — not here unless overriding.

# --- EDIT THESE ---------------------------------------------------
# (usually empty — add only if this PC needs different paths than .env)

# --- OPTIONAL (defaults work for most setups) ---------------------
MMX_EPHEMERAL_BROWSER=true

# SCRAPER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# SCRAPER_EXECUTABLE_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
# MMX_BUILD_TO_DIR=override with semicolon-separated folder list
