# Raspberry Pi settings (not used on Windows)
# Setup:  cp .env.pi.example .env.production
# Workbook paths can stay in .env (MMX_BUILD_TO_DIR_PI) — only fill EDIT THESE if Pi-only overrides needed.

# --- EDIT THESE ---------------------------------------------------
SCRAPER_USERNAME=
SCRAPER_PASSWORD=

# Change "pi" if your Linux username is different (only if not using paths from .env)
# MMX_USER_DATA_DIR=/home/pi/mmx-report-automation/data/browser-profile
# MMX_WORK_DIR=/home/pi/mmx-report-automation/data
# MMX_BUILD_TO_DIR_PI="/home/orbro/OneDrive/Taco Bell Files/Build Tos/3811"
# MMX_BUILD_TO_FILENAME="Build to.xlsx"

# --- OPTIONAL (defaults work for most setups) ---------------------
SCRAPER_EXECUTABLE_PATH=/usr/bin/chromium
SCRAPER_HEADLESS=true
MMX_STORE_NAME="3811 Chirnside Park"
MMX_TIME_ZONE=Australia/Melbourne
MMX_GATE_SCHEDULE_START=9
MMX_GATE_SCHEDULE_END=23
MMX_NAV_TIMEOUT_MS=45000
MMX_DOWNLOAD_WAIT_MS=120000
MMX_LOGIN_WAIT_MS=300000
