# mmx-report-automation — shared settings (Windows + Pi)
# Setup:  cp .env.example .env
#         cp .env.windows.example .env.windows   (PC only)
#         cp .env.pi.example .env.production     (Pi only)

# --- EDIT THESE ---------------------------------------------------
SCRAPER_USERNAME=
SCRAPER_PASSWORD=
MMX_STORE_NAME="3811 Chirnside Park"

# Build To folder — first folder/workbook that exists on this machine wins
MMX_BUILD_TO_DIR_ONEDRIVE="C:\Users\apowe\OneDrive\Taco Bell Files\Build Tos\3811"
MMX_BUILD_TO_DIR_PI="/home/orbro/OneDrive/Taco Bell Files/Build Tos/3811"
MMX_BUILD_TO_DIR_FALLBACK=./data/workbooks
MMX_BUILD_TO_FILENAME="Build to.xlsx"

# Report downloads use a temp folder under MMX_WORK_DIR/out (deleted after merge).
# Set MMX_DOWNLOAD_DIR only to override (avoid same-as-workbook — nothing is kept in Build To).
# MMX_DOWNLOAD_DIR=./data/inbox

# --- OPTIONAL (defaults work for most setups) ---------------------
# Or encrypted credentials instead of username/password:
# SCRAPER_CREDENTIALS_ENCRYPTED=
# SCRAPER_CREDENTIALS_KEY=

SCRAPER_HEADLESS=true
MMX_LOGIN_SUCCESS_URL_PART=MMS_Stores

MMX_WORK_DIR=./data

MMX_TIME_ZONE=Australia/Melbourne
MMX_GATE_SCHEDULE_START=8
MMX_GATE_SCHEDULE_END=23
MMX_GATE_CHECK_INTERVAL_MINUTES=15

# Continuous sales + labour workers (parallel, always-on)
MMX_CONTINUOUS_REQUIRE_PERSISTENT_PROFILE=true
MMX_LABOUR_REFRESH_MINUTES=2
# MMX_LABOUR_STORES=3811 Chirnside Park;1234 Example Store
MMX_SALES_INTERVAL_MINUTES=2
# MMX_SALES_REPORT_URL=
# MMX_SALES_READY_SELECTOR=
# MMX_LABOUR_SCHEDULER_URL=https://tacobellau.macromatix.net/MMS_Stores_LabourScheduler.aspx?MenuCustomItemID=249
# MMX_LABOUR_DAY_VIEW_SELECTOR=
# MMX_LABOUR_STORE_INPUT_SELECTOR=
# MMX_LABOUR_STORE_APPLY_SELECTOR=
# MMX_LABOUR_READY_SELECTOR=
# MMX_WORKER_RETRY_BACKOFF_SECONDS=30
# MMX_WORKER_MAX_RETRY_BACKOFF_SECONDS=300

MMX_TEMPLATE_ALWAYS_COPY=false
MMX_NAV_TIMEOUT_MS=45000
MMX_DOWNLOAD_WAIT_MS=120000
MMX_LOGIN_WAIT_MS=300000

# SCRAPER_EXECUTABLE_PATH=        # set in .env.windows or .env.pi
# SCRAPER_SLOW_MO_MS=100
# SCRAPER_DEVTOOLS=false
# MMX_GATE_URL=                   # overrides pipeline.json gate.url
# MMX_BUILD_TO_DIR=               # optional semicolon-separated folder list
# MMX_TEMPLATE_LOCAL=             # optional semicolon-separated workbook list (legacy override)
# MMX_TEMPLATE_SYNC=              # extra copy after merge (semicolon-separated)
# MMX_TEMPLATE_SOURCE=            # UNC master workbook
# MMX_TEMPLATE_PUBLISH=           # write-back to server after merge
# MMX_ORDER_DATE=tomorrow
# MMX_SKIP_WORKBOOK_RECALC=false
# MMX_BUILDTO_WORKBOOK_PASSWORD=123456
# MMX_REPORTS_CONCURRENT=1
# MMX_REPORTS_CONCURRENT_STAGGER_MS=500
# MMX_PDF_EXPORT_ENABLED=false
# MMX_PDF_EXPORT_TABS=Summary;Inventory;Orders
# MMX_PDF_EXPORT_DIR=./data/out/pdfs
# MMX_EMAIL_ENABLED=false
# MMX_EMAIL_SEND_ON_DRY_RUN=true
# MMX_EMAIL_SMTP_HOST=smtp.office365.com
# MMX_EMAIL_SMTP_PORT=587
# MMX_EMAIL_SMTP_SECURE=false
# MMX_EMAIL_SMTP_USER=you@domain.com
# MMX_EMAIL_SMTP_PASS=
# MMX_EMAIL_FROM=you@domain.com
# MMX_EMAIL_TO=ops@domain.com;manager@domain.com
# MMX_EMAIL_CC=
# MMX_EMAIL_SUBJECT_PREFIX=3811 Build To PDFs
# MMX_EMAIL_BODY=Attached are the latest Build To PDF exports.
# MMX_MANUAL_FILL_PATH=            # optional absolute/relative path for Build To Manual Fill workbook attachment
# MMX_MANUAL_FILL_FILENAME=Build To Manual Fill.xlsx
