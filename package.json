{
  "name": "area-coach-tools",
  "version": "1.0.0",
  "description": "Area Coach Tools - forecast, Excel build-to, daily reports, subscriptions, logs.",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "forecast-scheduler": "node scripts/run-forecast-scheduler.js",
    "desktop:start": "npm --prefix desktop start",
    "desktop:dist": "npm --prefix desktop run dist",
    "desktop:pack": "npm --prefix desktop run pack",
    "desktop:install": "npm --prefix desktop install",
    "buildto:install": "npm --prefix mmx-report-automation install --no-fund --no-audit",
    "puppeteer:install": "puppeteer browsers install chrome",
    "postinstall": "npm run buildto:install && npm run puppeteer:install",
    "setup:build": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/Build-SetupExe.ps1",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:logs": "pm2 logs area-coach-tools"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "dotenv": "^10.0.0",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "nodemailer": "^6.9.16",
    "puppeteer": "24.43.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  },
  "license": "ISC",
  "type": "commonjs"
}
